generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
}

enum Role {
  USER
  ADMIN
}

model User {
  id          String   @id @default(uuid())
  firebaseUid String   @unique
  email       String?  @unique
  name        String?
  photoUrl    String?
  language    String   @default("pt")
  plan        Plan     @default(FREE)
  role        Role     @default(USER)

  // Gamification
  xp            Int       @default(0)
  streak        Int       @default(0)
  level         String    @default("Iniciante")
  lastStudyDate DateTime?

  // Stripe (inlined from old Subscription model)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  subscriptionStatus   String?   @default("inactive")
  currentPeriodEnd     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  documents     Document[]
  flashcardSets FlashcardSet[]
  quizzes       Quiz[]
  dailyUsages   DailyUsage[]
}

model Document {
  id        String   @id @default(uuid())
  userId    String
  title     String
  subject   String?
  content   String?
  fileUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  quizzes       Quiz[]
  flashcardSets FlashcardSet[]
}

model FlashcardSet {
  id         String   @id @default(uuid())
  userId     String
  documentId String?
  topic      String
  language   String?
  createdAt  DateTime @default(now())

  user     User       @relation(fields: [userId], references: [id])
  document Document?  @relation(fields: [documentId], references: [id])
  cards    Flashcard[]
}

model Flashcard {
  id             String   @id @default(uuid())
  flashcardSetId String
  front          String
  back           String
  explain        String?
  imageUrl       String?
  imageQuery     String?
  createdAt      DateTime @default(now())

  flashcardSet FlashcardSet @relation(fields: [flashcardSetId], references: [id], onDelete: Cascade)
}

model Quiz {
  id         String   @id @default(uuid())
  userId     String
  documentId String?
  topic      String?
  language   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  document  Document?  @relation(fields: [documentId], references: [id])
  questions Question[]
}

model Question {
  id           String   @id @default(uuid())
  quizId       String
  question     String
  options      String[]
  correctIndex Int
  imageUrl     String?
  imageQuery   String?
  createdAt    DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model DailyUsage {
  id                  String @id @default(uuid())
  userId              String
  date                String
  flashcardsGenerated Int    @default(0)
  quizzesGenerated    Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
